# OpenKeep Voyage embeddings example
# Copy the values you need into `.env`.

ACTIVE_EMBEDDING_PROVIDER=voyage

# Voyage docs:
# https://docs.voyageai.com/docs/embeddings
# API keys:
# https://docs.voyageai.com/docs/api-key-and-installation

VOYAGE_API_KEY=
VOYAGE_API_BASE_URL=https://api.voyageai.com/v1
VOYAGE_EMBEDDING_MODEL=voyage-3-large

# Run:
# pnpm test:e2e:voyage
