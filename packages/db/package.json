{
  "name": "@openkeep/db",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
