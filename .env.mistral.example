# OpenKeep Mistral OCR example
# Copy the values you need into `.env`.

ACTIVE_PARSE_PROVIDER=mistral-ocr
FALLBACK_PARSE_PROVIDER=local-ocr

# Mistral OCR docs:
# https://docs.mistral.ai/capabilities/document_ai/basic_ocr/
# https://docs.mistral.ai/api/endpoint/ocr

MISTRAL_API_KEY=
MISTRAL_OCR_BASE_URL=https://api.mistral.ai
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Run:
# pnpm test:e2e:mistral
