# OpenKeep — Mistral as chat/LLM provider
# Copy the values you need into `.env`.
#
# This configures Mistral as the chat model used for:
#   - Document summarization
#   - Document Q&A
#   - Search answer generation
#   - Correspondent extraction
#
# Mistral chat docs:
#   https://docs.mistral.ai/capabilities/completion/
#   https://docs.mistral.ai/api/
#
# Available chat models (as of 2025):
#   mistral-small-latest   — fast, cost-effective
#   mistral-medium-latest  — balanced
#   mistral-large-latest   — most capable
#
# The chat model is resolved with this priority:
#   1. OPENAI_API_KEY  → OpenAI
#   2. GEMINI_API_KEY  → Gemini
#   3. MISTRAL_API_KEY → Mistral
#
# To use Mistral as the chat provider, make sure OPENAI_API_KEY and
# GEMINI_API_KEY are NOT set (or empty).

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Optional: override the Mistral API base URL (default: https://api.mistral.ai)
# MISTRAL_OCR_BASE_URL=https://api.mistral.ai

# Optional: also use Mistral for embeddings
# ACTIVE_EMBEDDING_PROVIDER=mistral
# MISTRAL_EMBEDDING_MODEL=mistral-embed

# Optional: also use Mistral for OCR
# ACTIVE_PARSE_PROVIDER=mistral-ocr
# MISTRAL_OCR_MODEL=mistral-ocr-latest
