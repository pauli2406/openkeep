# OpenKeep Google Cloud Document AI example
# Copy the values you need into `.env`.

# Active provider:
# - google-document-ai-enterprise-ocr
# - google-document-ai-gemini-layout-parser
ACTIVE_PARSE_PROVIDER=google-document-ai-enterprise-ocr
FALLBACK_PARSE_PROVIDER=local-ocr

# Optional semantic indexing with Gemini embeddings:
ACTIVE_EMBEDDING_PROVIDER=google-gemini
GEMINI_EMBEDDING_MODEL=

# Google Cloud Document AI docs:
# Enterprise OCR:
# https://docs.cloud.google.com/document-ai/docs/enterprise-document-ocr
# Layout parser / chunking:
# https://docs.cloud.google.com/document-ai/docs/layout-parse-chunk
# Processor catalog:
# https://docs.cloud.google.com/document-ai/docs/processors-list

GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=eu

# Set one of these:
GOOGLE_CLOUD_ACCESS_TOKEN=
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON=

# Enterprise OCR processor id:
GOOGLE_DOCUMENT_AI_ENTERPRISE_PROCESSOR_ID=

# Gemini layout parser processor id:
GOOGLE_DOCUMENT_AI_GEMINI_PROCESSOR_ID=

# Run:
# pnpm test:e2e:google
# or
# pnpm test:e2e:google:gemini
#
# Optional embedding E2E:
# pnpm test:e2e:gemini-embeddings
