{
  "name": "@openkeep/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "build": "tsup src/main.ts src/openapi.ts --format cjs --target node22 --out-dir dist",
    "dev": "tsx watch src/main.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run test/deterministic-metadata.extractor.spec.ts test/local-ocr.provider.spec.ts test/normalization.util.spec.ts",
    "test:integration": "RUN_TESTCONTAINERS=1 vitest run test/api.integration.spec.ts",
    "test:ocr": "RUN_OCR_ACCEPTANCE=1 vitest run test/local-ocr.acceptance.spec.ts",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:ocr",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "openapi:generate": "pnpm build && node dist/openapi.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "fastify": "^5.6.1",
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.8",
    "@nestjs/swagger": "^11.2.3",
    "@openkeep/config": "workspace:*",
    "@openkeep/db": "workspace:*",
    "@openkeep/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.43.1",
    "execa": "^9.6.0",
    "mime-types": "^2.1.35",
    "nestjs-zod": "^4.3.1",
    "pg": "^8.16.3",
    "pg-boss": "^10.1.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.8",
    "@types/mime-types": "^2.1.4",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "testcontainers": "^11.7.0",
    "vitest": "^3.2.4"
  }
}
