# OpenKeep local development environment
# Copy to `.env` and fill only the sections you plan to use.
# `.env` is gitignored.

# -----------------------------------------------------------------------------
# Core app
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Docs site and Typesense DocSearch
# The docs service reads the browser-facing Typesense URL below.
# Docker Compose bootstraps a search-only key automatically from the admin key.
# -----------------------------------------------------------------------------
DOCS_SITE_URL=https://openkeep.local
TYPESENSE_COLLECTION_NAME=openkeep-docs
TYPESENSE_ADMIN_API_KEY=change-me-typesense-admin-key
TYPESENSE_PUBLIC_HOST=localhost
TYPESENSE_PUBLIC_PORT=8108
TYPESENSE_PUBLIC_PROTOCOL=http
# Optional scraper overrides when you are not indexing the compose-hosted docs site:
DOCSEARCH_START_URL=http://docs:3001
DOCSEARCH_SITEMAP_URL=http://docs:3001/sitemap.xml
DOCSEARCH_STOP_URL=http://docs:3001/search

# -----------------------------------------------------------------------------
# Database and queue
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://openkeep:openkeep@localhost:5432/openkeep
PG_BOSS_SCHEMA=pgboss

# -----------------------------------------------------------------------------
# Object storage
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=openkeep
MINIO_SECRET_KEY=openkeep123
MINIO_BUCKET=documents

# -----------------------------------------------------------------------------
# Auth
# Replace these for any non-throwaway environment.
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-change-me-change-me-1234
JWT_REFRESH_SECRET=change-me-change-me-change-me-5678
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-this-password
OWNER_NAME=OpenKeep Owner

# -----------------------------------------------------------------------------
# Processing mode
# `PROVIDER_MODE` is reserved for later AI-assisted extraction modes.
# Current parse-provider routing is controlled by `ACTIVE_PARSE_PROVIDER`.
# -----------------------------------------------------------------------------
SKIP_EXTERNAL_INIT=false
PROVIDER_MODE=hybrid

# -----------------------------------------------------------------------------
# Parse provider selection
# Supported values:
#   local-ocr
#   google-document-ai-enterprise-ocr
#   google-document-ai-gemini-layout-parser
#   amazon-textract
#   azure-ai-document-intelligence
#   mistral-ocr
#
# Optional fallback is only used on hard parse failures.
# Recommended local default:
#   ACTIVE_PARSE_PROVIDER=local-ocr
# -----------------------------------------------------------------------------
ACTIVE_PARSE_PROVIDER=local-ocr
FALLBACK_PARSE_PROVIDER=

# -----------------------------------------------------------------------------
# Local OCR
# Requires ocrmypdf, tesseract, Poppler, ImageMagick, and language data.
# OCR acceptance tests currently use `deu+eng`.
# -----------------------------------------------------------------------------
OCR_LANGUAGES=deu+eng

# -----------------------------------------------------------------------------
# Parse-provider execution limits
# -----------------------------------------------------------------------------
PARSE_PROVIDER_TIMEOUT_SECONDS=120
PARSE_PROVIDER_MAX_PAGES=300
PARSE_PROVIDER_MAX_BYTES=52428800

# -----------------------------------------------------------------------------
# Review and retry thresholds
# -----------------------------------------------------------------------------
REVIEW_CONFIDENCE_THRESHOLD=0.65
OCR_EMPTY_TEXT_THRESHOLD=20
PROCESSING_RETRY_LIMIT=2
PROCESSING_RETRY_DELAY_SECONDS=30

# -----------------------------------------------------------------------------
# API limits
# Default upload cap is 64 MiB.
# -----------------------------------------------------------------------------
MAX_UPLOAD_BYTES=67108864
SEARCH_DEFAULT_PAGE_SIZE=20
SEARCH_MAX_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# LLM / embedding providers
# Set `ACTIVE_CHAT_PROVIDER` to pin chat to one provider even when multiple keys
# are configured. Leave it empty to use the default fallback order:
#   openai -> gemini -> mistral
#
# Embeddings power `POST /api/search/semantic` and document-chunk indexing.
# Set `ACTIVE_EMBEDDING_PROVIDER` only when you want semantic indexing enabled.
#
# Supported chat values:
#   openai
#   gemini
#   mistral
#
# Supported embedding values:
#   openai
#   google-gemini
#   voyage
#   mistral
#
# Official docs:
#   OpenAI embeddings:
#   https://platform.openai.com/docs/guides/embeddings
#   Gemini embeddings:
#   https://ai.google.dev/gemini-api/docs/embeddings
#   Voyage embeddings:
#   https://docs.voyageai.com/docs/embeddings
#   Mistral embeddings:
#   https://docs.mistral.ai/api/endpoint/embeddings
# -----------------------------------------------------------------------------
ACTIVE_CHAT_PROVIDER=
ACTIVE_EMBEDDING_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=
VOYAGE_API_KEY=
VOYAGE_API_BASE_URL=https://api.voyageai.com/v1
VOYAGE_EMBEDDING_MODEL=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_EMBEDDING_MODEL=

# -----------------------------------------------------------------------------
# Google Cloud Document AI
# Used by:
#   google-document-ai-enterprise-ocr
#   google-document-ai-gemini-layout-parser
#
# Official docs:
#   Enterprise Document OCR:
#   https://docs.cloud.google.com/document-ai/docs/enterprise-document-ocr
#   Layout parser / chunking:
#   https://docs.cloud.google.com/document-ai/docs/layout-parse-chunk
#   Processor list:
#   https://docs.cloud.google.com/document-ai/docs/processors-list
#
# Required for live E2E:
# - GOOGLE_CLOUD_PROJECT_ID
# - GOOGLE_CLOUD_LOCATION
# - either GOOGLE_CLOUD_ACCESS_TOKEN or GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON
# - processor ID matching the selected provider
#
# Tip:
# - GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON should be a single-line JSON string.
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=eu
GOOGLE_CLOUD_ACCESS_TOKEN=
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON=
GOOGLE_DOCUMENT_AI_ENTERPRISE_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_GEMINI_PROCESSOR_ID=

# -----------------------------------------------------------------------------
# Amazon Textract
# Official docs:
#   https://docs.aws.amazon.com/textract/latest/dg/getting-started.html
# Required for live E2E:
# - AWS_REGION
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
# Optional:
# - AWS_SESSION_TOKEN
# -----------------------------------------------------------------------------
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# -----------------------------------------------------------------------------
# Azure AI Document Intelligence
# Official docs:
#   Resource setup:
#   https://learn.microsoft.com/en-us/azure/applied-ai-services/form-recognizer/create-a-form-recognizer-resource
# Required for live E2E:
# - AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT
# - AZURE_DOCUMENT_INTELLIGENCE_API_KEY
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=

# -----------------------------------------------------------------------------
# Mistral OCR
# Official docs:
#   OCR capability:
#   https://docs.mistral.ai/capabilities/document_ai/basic_ocr/
#   OCR API endpoint:
#   https://docs.mistral.ai/api/endpoint/ocr
# Required for live E2E:
# - MISTRAL_API_KEY
# Optional:
# - MISTRAL_MODEL
# - MISTRAL_OCR_BASE_URL
# - MISTRAL_OCR_MODEL
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=
MISTRAL_OCR_BASE_URL=https://api.mistral.ai
MISTRAL_OCR_MODEL=mistral-ocr-latest
