# OpenKeep OpenAI embeddings example
# Copy the values you need into `.env`.

ACTIVE_EMBEDDING_PROVIDER=openai

# OpenAI docs:
# https://platform.openai.com/docs/guides/embeddings
# API keys:
# https://platform.openai.com/api-keys

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional text-generation settings used later in the roadmap:
OPENAI_MODEL=gpt-4.1-mini

# Run:
# pnpm test:e2e:openai-embeddings
